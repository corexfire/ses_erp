model MarketplaceChannel {
  id            String    @id @default(cuid())
  tenantId      String
  code          String
  name          String
  type          String
  iconUrl       String?
  apiEndpoint   String?
  clientId      String?
  clientSecret  String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listings      MarketplaceListing[]
  syncLogs      MarketplaceSyncLog[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, type])
}

model MarketplaceListing {
  id                      String    @id @default(cuid())
  tenantId                String
  channelId               String
  itemId                  String?
  productName             String
  productSku              String
  marketplaceProductId    String?
  marketplaceUrl          String?
  sellingPrice            Decimal   @db.Decimal(18, 2)
  stockQty                Int
  syncStock               Boolean  @default(true)
  syncPrice               Boolean  @default(true)
  syncStatus              String   @default("PENDING")
  lastSyncAt              DateTime?
  lastSyncError           String?
  isActive                Boolean  @default(true)
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel                 MarketplaceChannel @relation(fields: [channelId], references: [id])
  item                    Item?     @relation(fields: [itemId], references: [id])
  syncLogs                MarketplaceSyncLog[]

  @@index([tenantId, channelId])
  @@index([tenantId, syncStatus])
  @@index([tenantId, itemId])
}

model MarketplaceSyncLog {
  id          String    @id @default(cuid())
  tenantId    String
  listingId   String
  channelId   String
  syncType    String
  status      String
  message     String?
  details     String?
  createdAt   DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  listing     MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  channel     MarketplaceChannel @relation(fields: [channelId], references: [id])

  @@index([tenantId, listingId])
  @@index([tenantId, channelId])
  @@index([tenantId, createdAt])
}
