generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                          String                      @id @default(cuid())
  name                        String                      @unique
  createdAt                   DateTime                    @default(now())
  periods                     AccountingPeriod[]
  warehouseZones              WarehouseZone[]
  approvalHistories           ApprovalHistory[]
  assetDisposals              AssetDisposal[]
  attendances                 Attendance[]
  bankAccounts                BankAccount[]
  bankReconciliations         BankReconciliation[]
  bankTransactions            BankTransaction[]
  billOfMaterials             BillOfMaterials[]
  billOfMaterialsItems        BillOfMaterialsItem[]
  binLocations                BinLocation[]
  bomOperations               BomOperation[]
  branches                    Branch[]
  budgets                     Budget[]
  calibrationLogs             CalibrationLog[]
  capaReports                 Capa[]
  carriers                    Carrier[]
  cashAccounts                CashAccount[]
  cashTransactions            CashTransaction[]
  coaAccounts                 CoaAccount[]
  commissionEntries           CommissionEntry[]
  commissionSchemes           CommissionScheme[]
  companyProfile              CompanyProfile?
  costCenters                 CostCenter[]
  costCenterAllocations       CostCenterAllocation[]
  courses                     Course[]
  courseEnrollments           CourseEnrollment[]
  currencies                  Currency[]
  customers                   Customer[]
  customerInvoices            CustomerInvoice[]
  customerInvoiceLines        CustomerInvoiceLine[]
  customerInvoicePayments     CustomerInvoicePayment[]
  portalActivities            CustomerPortalActivity[]
  portalUsers                 CustomerPortalUser[]
  customerReceipts            CustomerReceipt[]
  delegations                 Delegation[]
  deliveryExceptions          DeliveryException[]
  deliveryOrders              DeliveryOrder[]
  deliveryOrderItems          DeliveryOrderItem[]
  discountRules               DiscountRule[]
  employees                   Employee[]
  equipment                   Equipment[]
  exchangeRates               ExchangeRate[]
  expenseClaims               ExpenseClaim[]
  fiscalYears                 FiscalYear[]
  fixedAssets                 FixedAsset[]
  fixedAssetDepreciations     FixedAssetDepreciation[]
  fleetVehicles               FleetVehicle[]
  marketplaceChannels         MarketplaceChannel[]
  marketplaceListings        MarketplaceListing[]
  marketplaceSyncLogs        MarketplaceSyncLog[]
  fsmHandovers                FsmHandover[]
  fsmServiceAppointments      FsmServiceAppointment[]
  fsmServiceOrders            FsmServiceOrder[]
  fsmServiceOrderItems        FsmServiceOrderItem[]
  fsmServiceReports           FsmServiceReport[]
  fsmSparePartCompatibilities FsmSparePartCompatibility[]
  goodsIssueItems             GoodsIssueItem[]
  goodsIssues                 GoodsIssueNote[]
  goodsReceiptItems           GoodsReceiptItem[]
  goodsReceipts               GoodsReceiptNote[]
  idBillings                  IdBilling[]
  inProcessQcs                InProcessQc[]
  interCompanyTransactions    InterCompanyTransaction[]
  inventoryForecasts          InventoryForecast[]
  items                       Item[]
  itemBarcodes                ItemBarcode[]
  batches                     ItemBatch[]
  itemGroups                  ItemGroup[]
  serials                     ItemSerial[]
  itemUoms                    ItemUom[]
  journalEntries              JournalEntry[]
  journalEntryLines           JournalEntryLine[]
  kpiEvaluations              KpiEvaluation[]
  landedCostAllocations       LandedCostAllocation[]
  landedCosts                 LandedCostVoucher[]
  leads                       Lead[]
  logisticsDrivers            LogisticsDriver[]
  maintenanceLogs             MaintenanceLog[]
  maintenanceLogParts         MaintenanceLogPart[]
  maintenanceRequests         MaintenanceRequest[]
  maintenanceSchedules        MaintenanceSchedule[]
  maintenanceTasks            MaintenanceTask[]
  campaigns                   MarketingCampaign[]
  mrpRuns                     MrpRun[]
  mrpSuggestions              MrpSuggestion[]
  nonConformanceReports       NonConformanceReport[]
  notificationChannelConfigs  NotificationChannelConfig[]
  notificationLogs            NotificationLog[]
  notificationPreferences     NotificationPreference[]
  notificationSchedules       NotificationSchedule[]
  notificationTemplates       NotificationTemplate[]
  nsfpRanges                  NsfpRange[]
  opportunities               Opportunity[]
  organizationUnits           OrganizationUnit[]
  packings                    Packing[]
  packingItems                PackingItem[]
  packingLists                PackingList[]
  paymentRequests             PaymentRequest[]
  payrollRuns                 PayrollRun[]
  pettyCashReplenishments     PettyCashReplenishment[]
  pickings                    Picking[]
  pickingItems                PickingItem[]
  pphWithholdings             PphWithholding[]
  priceLists                  PriceList[]
  priceListItems              PriceListItem[]
  priceRules                  PriceRule[]
  productionCosts             ProductionCost[]
  productionCostDetails       ProductionCostDetail[]
  productionIssues            ProductionIssue[]
  productionIssueItems        ProductionIssueItem[]
  productionReceipts          ProductionReceipt[]
  profitCenters               ProfitCenter[]
  progressClaims              ProgressClaim[]
  progressInvoices            ProgressInvoice[]
  proofOfDeliveries           ProofOfDelivery[]
  purchaseInvoices            PurchaseInvoice[]
  purchaseInvoiceItems        PurchaseInvoiceItem[]
  purchaseOrders              PurchaseOrder[]
  purchaseOrderItems          PurchaseOrderItem[]
  purchaseRequisitions        PurchaseRequisition[]
  purchaseRequisitionItems    PurchaseRequisitionItem[]
  purchaseReturns             PurchaseReturn[]
  purchaseReturnItems         PurchaseReturnItem[]
  putaways                    Putaway[]
  putawayItems                PutawayItem[]
  qcInspections               QcInspection[]
  qcInspectionItems           QcInspectionItem[]
  qualityDocuments            QualityDocument[]
  supportDocuments            SupportDocument[]
  supportCompliances          SupportCompliance[]
  supportKpis                 SupportKpi[]
  supportSustainability       SupportSustainability[]
  recruitmentCandidates       RecruitmentCandidate[]
  rentalBillings              RentalBilling[]
  rentalContracts             RentalContract[]
  rentalMaintenances          RentalMaintenance[]
  rfqs                        Rfq[]
  rfqItems                    RfqItem[]
  rfqVendors                  RfqVendor[]
  roles                       Role[]
  routeTemplates              RouteTemplate[]
  activities                  SalesActivity[]
  salesInvoices               SalesInvoice[]
  salesInvoiceItems           SalesInvoiceItem[]
  salesOrders                 SalesOrder[]
  salesOrderItems             SalesOrderItem[]
  salesQuotations             SalesQuotation[]
  salesQuotationItems         SalesQuotationItem[]
  salesReturns                SalesReturn[]
  salesReturnItems            SalesReturnItem[]
  salesSubscriptions          SalesSubscription[]
  tickets                     ServiceTicket[]
  shifts                      Shift[]
  shipments                   Shipment[]
  shopFloorLogs               ShopFloorLog[]
  shopFloorTimers             ShopFloorTimer[]
  stagingLoads                StagingLoad[]
  stockBalances               StockBalance[]
  stockCounts                 StockCount[]
  stockCountItems             StockCountItem[]
  stockLedgers                StockLedger[]
  stockTransfers              StockTransfer[]
  stockTransferItems          StockTransferItem[]
  suppliers                   Supplier[]
  supplierInvoices            SupplierInvoice[]
  supplierInvoiceLines        SupplierInvoiceLine[]
  supplierInvoicePayments     SupplierInvoicePayment[]
  supplierRatings             SupplierRating[]
  taxCodes                    TaxCode[]
  taxEqualizations            TaxEqualization[]
  taxInvoices                 TaxInvoice[]
  teams                       Team[]
  teamMembers                 TeamMember[]
  threeWayMatchings           ThreeWayMatching[]
  transporters                Transporter[]
  tripCheckpoints             TripCheckpoint[]
  tripCosts                   TripCost[]
  tripPlans                   TripPlan[]
  uoms                        Uom[]
  uomConversions              UomConversion[]
  users                       User[]
  valuationLayers             ValuationLayer[]
  vendorPayments              VendorPayment[]
  vendorActivities            VendorPortalActivity[]
  vendorPortals               VendorPortalUser[]
  warehouses                  Warehouse[]
  wavePickings                WavePicking[]
  workOrders                  WorkOrder[]
  workOrderComponents         WorkOrderComponent[]
  workOrderOperations         WorkOrderOperation[]
  workflowDefinitions         WorkflowDefinition[]
  workflowInstances           WorkflowInstance[]
  workflowRules               WorkflowRule[]
  workflowSteps               WorkflowStep[]
}

model User {
  id                           String                   @id @default(cuid())
  tenantId                     String
  email                        String                   @unique
  name                         String?
  passwordHash                 String
  isActive                     Boolean                  @default(true)
  createdAt                    DateTime                 @default(now())
  isSuperAdmin                 Boolean                  @default(false)
  approvalHistories            ApprovalHistory[]
  assignedCapas                Capa[]                   @relation("CapaAssignee")
  commissionEntries            CommissionEntry[]        @relation("UserToCommissionEntry")
  delegatedFrom                Delegation[]             @relation("DelegationFrom")
  delegatedTo                  Delegation[]             @relation("DelegationTo")
  fsmHandovers                 FsmHandover[]            @relation("HandoverTechnician")
  assignedFsmAppointments      FsmServiceAppointment[]  @relation("AppointmentTechnician")
  assignedLeads                Lead[]
  assignedNcrs                 NonConformanceReport[]   @relation("NcrAssignee")
  reportedNcrs                 NonConformanceReport[]   @relation("NcrReporter")
  notificationLogs             NotificationLog[]        @relation("NotificationRecipient")
  notificationPreferences      NotificationPreference[]
  createdNotificationSchedules NotificationSchedule[]   @relation("NotificationScheduleCreator")
  ownedOpportunities           Opportunity[]            @relation("OpportunityOwner")
  ownedQualityDocuments        QualityDocument[]
  assignedActivities           SalesActivity[]          @relation("ActivityAssignee")
  assignedTickets              ServiceTicket[]          @relation("TicketAssignee")
  tenant                       Tenant                   @relation(fields: [tenantId], references: [id])
  roles                        UserRole[]
  workflowInstances            WorkflowInstance[]       @relation("WorkflowInstanceAssignee")
  assignedTasks                WbsTask[]                @relation("TaskAssignee")
  teams                        TeamMember[]
  managedWarehouses            Warehouse[]              @relation(name: "WarehouseManager")
}

model Lead {
  id               String          @id @default(cuid())
  tenantId         String
  code             String
  name             String
  email            String?
  phone            String?
  source           String?
  status           LeadStatus      @default(NEW)
  assignedToUserId String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  assignedTo       User?           @relation(fields: [assignedToUserId], references: [id])
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunities    Opportunity[]
  activities       SalesActivity[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model Customer {
  id                 String               @id @default(cuid())
  tenantId           String
  code               String
  name               String
  email              String?
  phone              String?
  address1           String?
  address2           String?
  city               String?
  province           String?
  postalCode         String?
  countryCode        String?              @default("ID")
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  npwp               String?
  nik                String?
  taxAddress         String?
  tenant             Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  portalUsers        CustomerPortalUser[]
  deliveryOrders     DeliveryOrder[]
  discountRules      DiscountRule[]
  fsmHandovers       FsmHandover[]
  fsmServiceOrders   FsmServiceOrder[]
  opportunities      Opportunity[]
  priceListItems     PriceListItem[]
  priceRules         PriceRule[]
  projects           Project[]
  rentalBillings     RentalBilling[]
  rentalContracts    RentalContract[]
  activities         SalesActivity[]
  salesInvoices      SalesInvoice[]
  salesOrders        SalesOrder[]
  salesQuotations    SalesQuotation[]
  salesReturns       SalesReturn[]
  salesSubscriptions SalesSubscription[]
  tickets            ServiceTicket[]

  @@unique([tenantId, code])
}

model SalesQuotation {
  id         String               @id @default(cuid())
  tenantId   String
  code       String
  customerId String
  issueDate  DateTime
  expiryDate DateTime?
  status     SalesDocStatus       @default(DRAFT)
  notes      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  orders     SalesOrder[]
  customer   Customer             @relation(fields: [customerId], references: [id])
  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items      SalesQuotationItem[]

  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

model SalesQuotationItem {
  id          String         @id @default(cuid())
  tenantId    String
  quotationId String
  lineNo      Int
  description String
  qty         Decimal        @db.Decimal(18, 4)
  uomCode     String?
  unitPrice   Decimal        @db.Decimal(18, 4)
  discount    Decimal?       @db.Decimal(18, 4)
  taxCodeId   String?
  quotation   SalesQuotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  taxCode     TaxCode?       @relation(fields: [taxCodeId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, quotationId, lineNo])
  @@index([tenantId, quotationId])
}

model SalesOrder {
  id                   String              @id @default(cuid())
  tenantId             String
  code                 String
  customerId           String
  quotationId          String?
  orderDate            DateTime
  status               SalesDocStatus      @default(DRAFT)
  workflowDefinitionId String?
  currentStepNo        Int?
  notes                String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  deliveryOrders       DeliveryOrder[]
  packings             Packing[]
  pickings             Picking[]
  invoices             SalesInvoice[]
  customer             Customer            @relation(fields: [customerId], references: [id])
  quotation            SalesQuotation?     @relation(fields: [quotationId], references: [id])
  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowDef          WorkflowDefinition? @relation(fields: [workflowDefinitionId], references: [id])
  items                SalesOrderItem[]
  returns              SalesReturn[]
  shipments            Shipment[]

  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

model SalesOrderItem {
  id          String     @id @default(cuid())
  tenantId    String
  orderId     String
  lineNo      Int
  description String
  qty         Decimal    @db.Decimal(18, 4)
  uomCode     String?
  unitPrice   Decimal    @db.Decimal(18, 4)
  discount    Decimal?   @db.Decimal(18, 4)
  taxCodeId   String?
  itemId      String?
  item        Item?      @relation(fields: [itemId], references: [id])
  order       SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  taxCode     TaxCode?   @relation(fields: [taxCodeId], references: [id])
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, orderId, lineNo])
  @@index([tenantId, orderId])
}

model SalesInvoice {
  id                String             @id @default(cuid())
  tenantId          String
  code              String
  customerId        String
  orderId           String?
  invoiceDate       DateTime
  status            SalesDocStatus     @default(DRAFT)
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  commissionEntries CommissionEntry[]
  customer          Customer           @relation(fields: [customerId], references: [id])
  order             SalesOrder?        @relation(fields: [orderId], references: [id])
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items             SalesInvoiceItem[]

  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

model SalesInvoiceItem {
  id          String       @id @default(cuid())
  tenantId    String
  invoiceId   String
  lineNo      Int
  description String
  qty         Decimal      @db.Decimal(18, 4)
  uomCode     String?
  unitPrice   Decimal      @db.Decimal(18, 4)
  discount    Decimal?     @db.Decimal(18, 4)
  taxCodeId   String?
  itemId      String?
  invoice     SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item        Item?        @relation(fields: [itemId], references: [id])
  taxCode     TaxCode?     @relation(fields: [taxCodeId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceId, lineNo])
  @@index([tenantId, invoiceId])
}

model SalesReturn {
  id         String            @id @default(cuid())
  tenantId   String
  code       String
  customerId String
  orderId    String?
  returnDate DateTime
  status     SalesDocStatus    @default(DRAFT)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  customer   Customer          @relation(fields: [customerId], references: [id])
  order      SalesOrder?       @relation(fields: [orderId], references: [id])
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items      SalesReturnItem[]

  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

model SalesReturnItem {
  id          String      @id @default(cuid())
  tenantId    String
  returnId    String
  lineNo      Int
  description String
  qty         Decimal     @db.Decimal(18, 4)
  uomCode     String?
  unitPrice   Decimal     @db.Decimal(18, 4)
  taxCodeId   String?
  itemId      String?
  item        Item?       @relation(fields: [itemId], references: [id])
  salesReturn SalesReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  taxCode     TaxCode?    @relation(fields: [taxCodeId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, returnId, lineNo])
  @@index([tenantId, returnId])
}

model PriceList {
  id        String          @id @default(cuid())
  tenantId  String
  code      String
  name      String
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     PriceListItem[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model PriceListItem {
  id            String    @id @default(cuid())
  tenantId      String
  priceListId   String
  itemCode      String
  uomCode       String?
  unitPrice     Decimal   @db.Decimal(18, 4)
  effectiveDate DateTime
  endDate       DateTime?
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  priceList     PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, priceListId])
  @@index([tenantId, itemCode])
  @@index([tenantId, customerId])
}

model PriceRule {
  id            String    @id @default(cuid())
  tenantId      String
  code          String
  name          String
  priority      Int       @default(100)
  isActive      Boolean   @default(true)
  itemCode      String
  uomCode       String?
  unitPrice     Decimal   @db.Decimal(18, 4)
  effectiveDate DateTime
  endDate       DateTime?
  customerId    String?
  customerGroup String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer? @relation(fields: [customerId], references: [id])
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, itemCode, effectiveDate])
  @@index([tenantId, customerId])
  @@index([tenantId, customerGroup])
}

model DiscountRule {
  id              String    @id @default(cuid())
  tenantId        String
  code            String
  name            String
  priority        Int       @default(100)
  isActive        Boolean   @default(true)
  itemCode        String?
  uomCode         String?
  discountPercent Decimal   @db.Decimal(9, 4)
  effectiveDate   DateTime
  endDate         DateTime?
  customerId      String?
  customerGroup   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  customer        Customer? @relation(fields: [customerId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, effectiveDate])
  @@index([tenantId, itemCode])
  @@index([tenantId, customerId])
  @@index([tenantId, customerGroup])
}

model Carrier {
  id           String        @id @default(cuid())
  tenantId     String
  code         String
  name         String
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipments    Shipment[]
  packingLists PackingList[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model Shipment {
  id             String          @id @default(cuid())
  tenantId       String
  code           String
  orderId        String?
  carrierId      String?
  trackingNo     String?
  shipDate       DateTime?
  deliveryDate   DateTime?
  status         ShipmentStatus  @default(CREATED)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deliveryOrders DeliveryOrder[]
  carrier        Carrier?        @relation(fields: [carrierId], references: [id])
  order          SalesOrder?     @relation(fields: [orderId], references: [id])
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model CommissionScheme {
  id        String            @id @default(cuid())
  tenantId  String
  code      String
  name      String
  rate      Decimal           @db.Decimal(18, 4)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  entries   CommissionEntry[]
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model CommissionEntry {
  id          String           @id @default(cuid())
  tenantId    String
  schemeId    String
  invoiceId   String?
  salesUserId String?
  baseAmount  Decimal          @db.Decimal(18, 4)
  amount      Decimal          @db.Decimal(18, 4)
  createdAt   DateTime         @default(now())
  invoice     SalesInvoice?    @relation(fields: [invoiceId], references: [id])
  salesUser   User?            @relation("UserToCommissionEntry", fields: [salesUserId], references: [id])
  scheme      CommissionScheme @relation(fields: [schemeId], references: [id])
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, schemeId])
}

model Supplier {
  id               String              @id @default(cuid())
  tenantId         String
  code             String
  name             String
  email            String?
  phone            String?
  address1         String?
  address2         String?
  city             String?
  province         String?
  postalCode       String?
  countryCode      String?             @default("ID")
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  bankAccount      String?
  bankName         String?
  npwp             String?
  paymentTerms     String?
  vendorGroup      String?
  goodsReceipts    GoodsReceiptNote[]
  landedCosts      LandedCostVoucher[]
  purchaseInvoices PurchaseInvoice[]
  purchaseOrders   PurchaseOrder[]
  purchaseReturns  PurchaseReturn[]
  rfqVendors       RfqVendor[]
  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ratings          SupplierRating[]
  tripCosts        TripCost[]
  portalUsers      VendorPortalUser[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
}

model PurchaseRequisition {
  id                   String                    @id @default(cuid())
  tenantId             String
  code                 String
  requestDate          DateTime
  status               ProcurementDocStatus      @default(DRAFT)
  notes                String?
  workflowDefinitionId String?
  currentStepNo        Int?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  costCenterId         String?
  department           String?
  estimatedTotal       Decimal                   @default(0) @db.Decimal(18, 4)
  tenant               Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflowDef          WorkflowDefinition?       @relation(fields: [workflowDefinitionId], references: [id])
  items                PurchaseRequisitionItem[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model PurchaseRequisitionItem {
  id             String              @id @default(cuid())
  tenantId       String
  requisitionId  String
  lineNo         Int
  description    String
  qty            Decimal             @db.Decimal(18, 4)
  uomCode        String?
  requiredDate   DateTime?
  estimatedPrice Decimal             @default(0) @db.Decimal(18, 4)
  itemId         String?
  requisition    PurchaseRequisition @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, requisitionId, lineNo])
  @@index([tenantId, requisitionId])
}

model Rfq {
  id             String               @id @default(cuid())
  tenantId       String
  code           String
  issueDate      DateTime
  status         ProcurementDocStatus @default(DRAFT)
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  closingDate    DateTime?
  department     String?
  title          String?
  purchaseOrders PurchaseOrder[]
